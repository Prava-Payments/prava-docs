{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Prava Payments Docs",
  "colors": {
    "primary": "#0D9488",
    "light": "#5EEAD4",
    "dark": "#0F766E"
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "fonts": {
    "heading": {
      "family": "Neue Haas Display",
      "weight": 500,
      "source": "/fonts/NeueHaasDisplayMedium.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "Inter"
    }
  },
  "background": {
    "image": {
      "light": "/images/bg-light.jpg",
      "dark": "/images/bg-dark.jpg"
    },
    "color": {
      "light": "#F0FDFA",
      "dark": "#07100E"
    }
  },
  "favicon": "/favicon.svg",
  "thumbnails": {
    "background": "images/brand-banner.png"
  },
  "seo": {
    "metatags": {
      "og:image": "/images/brand-banner.png",
      "twitter:image": "/images/brand-banner.png",
      "twitter:card": "summary_large_image"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Developer Guide",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "use-cases",
              "concepts/how-it-works",
              "choosing-your-integration",
              "quickstart",
              "authentication",
              "dashboard"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/add-payments-to-your-ai-app",
              "guides/rest-checkout-walkthrough",
              "guides/go-live-checklist",
              "guides/compliance"
            ]
          },
          {
            "group": "Prava SDK",
            "pages": [
              "sdk/overview",
              "sdk/integration-modes",
              "sdk/cards/collect-pan"
            ]
          },
          {
            "group": "Prava MCP",
            "pages": [
              "mcp/overview",
              "mcp/connect",
              "mcp/tools"
            ]
          },
          {
            "group": "Prava CLI",
            "pages": [
              "prava-pay/overview",
              "prava-pay/quickstart",
              "prava-pay/skills",
              "prava-pay/linking",
              "prava-pay/sessions",
              "prava-pay/shopping",
              "prava-pay/your-wallet",
              "prava-pay/troubleshooting"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "changelog",
              "ai"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Server-Side API",
            "pages": [
              "api-reference/overview",
              "api-reference/create-session",
              "api-reference/revoke-session",
              "api-reference/list-cards",
              "api-reference/delete-card",
              "api-reference/get-payment-result",
              "api-reference/report-status"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "api-reference/errors",
              "api-reference/test-cards",
              "api-reference/testing"
            ]
          }
        ]
      },
      {
        "tab": "Concepts",
        "groups": [
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/payments",
              "concepts/accounts",
              "concepts/guardrails",
              "concepts/glossary"
            ]
          }
        ]
      },
      {
        "tab": "Capabilities",
        "groups": [
          {
            "group": "Shopping",
            "pages": [
              "integration/overview",
              "integration/ucp",
              "integration/browser-harness",
              "integration/merchants"
            ]
          },
          {
            "group": "Coming Soon",
            "pages": [
              "integration/travel",
              "integration/dining"
            ]
          }
        ]
      },
      {
        "tab": "FAQ",
        "groups": [
          {
            "group": "FAQ",
            "pages": [
              "developer-faq",
              "integration/faqs"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Blog",
        "href": "https://www.prava.space/blog"
      },
      {
        "label": "Support",
        "href": "mailto:support@prava.space"
      }
    ]
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/PravaPayments",
      "github": "https://github.com/Prava-Payments",
      "linkedin": "https://www.linkedin.com/company/prava-payments/"
    }
  }
}
